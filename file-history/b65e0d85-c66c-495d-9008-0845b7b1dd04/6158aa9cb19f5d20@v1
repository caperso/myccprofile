import { segmentsTransform } from '../segments.transform';

describe('segmentsTransform ', () => {
  describe('toEntity', () => {
    it('return empty decks when seatMapsApi cannot match segmentsApi', () => {
      const result = segmentsTransform.toEntity({
        segmentsApi: [{ id: 2, pnrID: 1 } as any],
        seatMapsApi: [{ segmentId: 1, decks: [], validatingCarrier: '' }],
        passengersApi: [],
        markUp: 5,
        seatSupplier: '',
      });

      expect(result).toEqual([
        {
          combinationId: `1-2`,
          decks: [],
          legend: {},
          markUp: '5',
          passengers: [],
          pnrId: '1',
          departureAirportCity: undefined,
          departureAirportCode: undefined,
          departureDateTime: undefined,
          legId: undefined,
          arrivalAirportCity: undefined,
          arrivalAirportCode: undefined,
          arrivalDateTime: undefined,
          flightNumber: undefined,
          seatSupplier: undefined,
          segmentId: 2,
          pnrRecordLocator: '',
        },
      ]);
    });

    it('return undefined markUp when markUp is undefined', () => {
      const resultWithoutMarkup = segmentsTransform.toEntity({
        segmentsApi: [{ id: 2, pnrID: 1, pnr: 'PNR123' } as any],
        seatMapsApi: [{ segmentId: 1, decks: [], validatingCarrier: '' }],
        passengersApi: [],
        markUp: undefined,
        seatSupplier: '',
      });
      expect(resultWithoutMarkup).toEqual([
        {
          combinationId: `1-2`,
          decks: [],
          legend: {},
          passengers: [],
          pnrId: '1',
          departureAirportCity: undefined,
          departureAirportCode: undefined,
          departureDateTime: undefined,
          legId: undefined,
          arrivalAirportCity: undefined,
          arrivalAirportCode: undefined,
          arrivalDateTime: undefined,
          flightNumber: undefined,
          seatSupplier: undefined,
          segmentId: 2,
          pnrRecordLocator: 'PNR123',
        },
      ]);
    });
  });
});
