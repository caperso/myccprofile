import { SeatSelection } from '@xivart/edge/types/postSale';

export const getCurrentPassengerSelection = (
  selections: SeatSelection[],
  currentPassengerIndex: string,
  currentCombinationId: string,
): SeatSelection | undefined =>
  selections.find(
    ({ passengerIndex, combinationId }) =>
      passengerIndex === currentPassengerIndex &&
      combinationId === currentCombinationId,
  );
